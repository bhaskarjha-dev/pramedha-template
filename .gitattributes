# Git LFS tracking for binary files in data-corpus/
# Uncomment the lines below if you use Git LFS:
# data-corpus/resumes/*.pdf filter=lfs diff=lfs merge=lfs -text
# data-corpus/resumes/*.docx filter=lfs diff=lfs merge=lfs -text
# data-corpus/documents/*.pdf filter=lfs diff=lfs merge=lfs -text
# data-corpus/media/*.png filter=lfs diff=lfs merge=lfs -text
# data-corpus/media/*.jpg filter=lfs diff=lfs merge=lfs -text
# data-corpus/media/*.mp4 filter=lfs diff=lfs merge=lfs -text

# Ensure consistent line endings
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf

# Mark generated files as generated (GitHub diffs collapse them)
resume/generated/** linguist-generated=true
